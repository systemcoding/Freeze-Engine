# GNU Make workspace makefile autogenerated by Premake

ifndef config
  config=debug_x64
endif

ifndef verbose
  SILENT = @
endif

ifeq ($(config),debug_x64)
  OpenGLEngine_config = debug_x64
endif
ifeq ($(config),release_x64)
  OpenGLEngine_config = release_x64
endif

PROJECTS := OpenGLEngine

.PHONY: all clean help $(PROJECTS) 

all: $(PROJECTS)

OpenGLEngine:
ifneq (,$(OpenGLEngine_config))
	@echo "==== Building OpenGLEngine ($(OpenGLEngine_config)) ===="
	@${MAKE} --no-print-directory -C . -f OpenGLEngine.make config=$(OpenGLEngine_config)
endif

clean:
	@${MAKE} --no-print-directory -C . -f OpenGLEngine.make clean

help:
	@echo "Usage: make [config=name] [target]"
	@echo ""
	@echo "CONFIGURATIONS:"
	@echo "  debug_x64"
	@echo "  release_x64"
	@echo ""
	@echo "TARGETS:"
	@echo "   all (default)"
	@echo "   clean"
	@echo "   OpenGLEngine"
	@echo ""
	@echo "For more information, see https://github.com/premake/premake-core/wiki"