build bin/Sandbox: CXX_EXECUTABLE_LINKER__Sandbox_Debug CMakeFiles/Sandbox.dir/engine/src/Application.cpp.o CMakeFiles/Sandbox.dir/engine/src/Buffer.cpp.o CMakeFiles/Sandbox.dir/engine/src/Camera.cpp.o CMakeFiles/Sandbox.dir/engine/src/KeyboardInput.cpp.o CMakeFiles/Sandbox.dir/engine/src/MouseInput.cpp.o CMakeFiles/Sandbox.dir/engine/src/RenderCommands.cpp.o CMakeFiles/Sandbox.dir/engine/src/Renderer2D.cpp.o CMakeFiles/Sandbox.dir/engine/src/Shader.cpp.o CMakeFiles/Sandbox.dir/engine/src/Sprite.cpp.o CMakeFiles/Sandbox.dir/engine/src/Texture.cpp.o CMakeFiles/Sandbox.dir/engine/src/VertexArray.cpp.o CMakeFiles/Sandbox.dir/engine/src/Window.cpp.o CMakeFiles/Sandbox.dir/engine/src/stb_image.cpp.o CMakeFiles/Sandbox.dir/sandbox/src/Player.cpp.o CMakeFiles/Sandbox.dir/sandbox/src/Sandbox.cpp.o CMakeFiles/Sandbox.dir/sandbox/src/SandboxApp.cpp.o CMakeFiles/Sandbox.dir/sandbox/src/World.cpp.o CMakeFiles/Sandbox.dir/lib/imgui/backends/imgui_impl_opengl3.cpp.o CMakeFiles/Sandbox.dir/lib/imgui/backends/imgui_impl_glfw.cpp.o CMakeFiles/Sandbox.dir/lib/imgui/imgui.cpp.o CMakeFiles/Sandbox.dir/lib/imgui/imgui_demo.cpp.o CMakeFiles/Sandbox.dir/lib/imgui/imgui_draw.cpp.o CMakeFiles/Sandbox.dir/lib/imgui/imgui_tables.cpp.o CMakeFiles/Sandbox.dir/lib/imgui/imgui_widgets.cpp.o | /usr/lib/x86_64-linux-gnu/libOpenGL.so /usr/lib/x86_64-linux-gnu/libGLX.so /usr/lib/x86_64-linux-gnu/libGLU.so /usr/lib/x86_64-linux-gnu/libGLEW.so /usr/lib/x86_64-linux-gnu/libglfw.so.3.3
  FLAGS = -g -g
  LINK_LIBRARIES = /usr/lib/x86_64-linux-gnu/libOpenGL.so  /usr/lib/x86_64-linux-gnu/libGLX.so  /usr/lib/x86_64-linux-gnu/libGLU.so  /usr/lib/x86_64-linux-gnu/libGLEW.so  /usr/lib/x86_64-linux-gnu/libglfw.so.3.3
  OBJECT_DIR = CMakeFiles/Sandbox.dir
  POST_BUILD = :
  PRE_LINK = :
  TARGET_FILE = bin/Sandbox
  TARGET_PDB = Sandbox.dbg


#############################################
# Utility command for edit_cache

build CMakeFiles/edit_cache.util: CUSTOM_COMMAND
  COMMAND = cd /home/revanth/Dev/projects/Freeze-Engine/build && /usr/bin/cmake -E echo No\ interactive\ CMake\ dialog\ available.
  DESC = No interactive CMake dialog available...
  restat = 1

build edit_cache: phony CMakeFiles/edit_cache.util


#############################################
# Utility command for rebuild_cache

build CMakeFiles/rebuild_cache.util: CUSTOM_COMMAND
  COMMAND = cd /home/revanth/Dev/projects/Freeze-Engine/build && /usr/bin/cmake --regenerate-during-build -S/home/revanth/Dev/projects/Freeze-Engine -B/home/revanth/Dev/projects/Freeze-Engine/build
  DESC = Running CMake to regenerate build system...
  pool = console
  restat = 1

build rebuild_cache: phony CMakeFiles/rebuild_cache.util

# =============================================================================
# Target aliases.

build Sandbox: phony bin/Sandbox

# =============================================================================
# Folder targets.

# =============================================================================

#############################################
# Folder: /home/revanth/Dev/projects/Freeze-Engine/build

build all: phony bin/Sandbox

